{
  "appId": "com.unleashed.game",
  "appName": "UNLEASHED!",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#1a1a2e",
      "androidSplashResourceName": "splash",
      "iosSplashResourceName": "Default",
      "showSpinner": false,
      "androidSpinnerStyle": "large",
      "spinnerColor": "#FFD93D"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a1a2e"
    }
  }
}

{
  "name": "unleashed-game",
  "version": "1.0.0",
  "description": "UNLEASHED! - Dog Park Chaos Endless Runner",
  "main": "capacitor.config.ts",
  "scripts": {
    "build": "cp -r www-src/* www/",
    "cap:init": "npx cap init 'UNLEASHED!' com.unleashed.game --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "keywords": [
    "game",
    "endless-runner",
    "dog",
    "html5"
  ],
  "author": "Sally",
  "license": "MIT",
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
